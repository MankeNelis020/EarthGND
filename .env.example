# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Resend
RESEND_API_KEY=re_your_key
RESEND_FROM_EMAIL=noreply@earthgnd.com

# Stripe — price IDs must match lib/plans.ts (see docs/stripe-pricing.md)
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_PRICE_STARTER=price_xxx_starter
STRIPE_PRICE_BASIC=price_xxx_basic
STRIPE_PRICE_PRO=price_xxx_pro
STRIPE_PRICE_CREDIT_1=price_xxx_credit_1
STRIPE_PRICE_CREDIT_10=price_xxx_credit_10
STRIPE_PRICE_CREDIT_50=price_xxx_credit_50

# Google Sheets CRM
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/your-script/exec

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://earthgnd.com

# Admin / gates (optional)
ADMIN_EMAILS=admin@example.com
IMPORT_API_KEY=your-import-api-key
DEBUG_METING_ENABLED=false

# Soil knowledge — Poort D gefaseerde activering
# SOIL_KNOWLEDGE_ACTIVE=true schakelt L2/L3/L4 empirie in (false = altijd L1)
SOIL_KNOWLEDGE_ACTIVE=false

# Poort D blend-parameters (alleen relevant als SOIL_KNOWLEDGE_ACTIVE=true)
EMPIRICAL_WEIGHT=0.1          # 0–1; 0.1 = 10% empirie, 90% literatuur (start staging)
ENABLED_CLASSES=geleidend     # 'geleidend' = klei (1) + veen (5); of '1,5'
CONFIDENCE_THRESHOLD=0.5      # onder drempel → L1, geen blend

# Noodstop: zet op 'true' voor directe terugval naar L1 (geen herstart nodig)
EMERGENCY_ROLLBACK=false
